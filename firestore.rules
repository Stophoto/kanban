rules_version = '2';

// Kanban security rules — one Firebase project, several independent household lists,
// each in its own collection. Publish these in the Firebase console:
// Firestore Database → Rules → Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    // Only Chris's and Carmyn's Google accounts can read or write the shared list.
    // This is the real lock — even if someone reached the app, Firestore rejects
    // them here. Keep this list identical to ALLOWED in index.html: to add or
    // remove a person, change BOTH places, then re-publish these rules.
    match /items/{itemId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['carmyn.pre@gmail.com', 'prefontainech@gmail.com'];
    }

    // Ben & Kat's shared list (ben/index.html) — both their Google accounts can
    // read and write it, same pattern as the parents' shared list above. Chris and
    // Carmyn can also view it (family-overview.html) but never write to it.
    match /items_ben/{itemId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['benprefontaine@gmail.com', 'katevers137@gmail.com'];
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['carmyn.pre@gmail.com', 'prefontainech@gmail.com'];
    }

    // Luke's own list (luke/index.html) — only Luke can add/edit/delete his own items.
    // Chris and Carmyn can view it (family-overview.html) but never write to it —
    // it stays his list to manage.
    match /items_luke/{itemId} {
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['lukeprefontaine@gmail.com', 'carmyn.pre@gmail.com', 'prefontainech@gmail.com'];
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'lukeprefontaine@gmail.com';
    }

    // Everything else is denied by default.
  }
}
